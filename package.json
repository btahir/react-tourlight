{
  "name": "react-tourlight",
  "version": "0.1.0",
  "description": "Beautiful onboarding tours & feature highlights for React. Zero dependencies.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/btahir/react-tourlight.git"
  },
  "bugs": {
    "url": "https://github.com/btahir/react-tourlight/issues"
  },
  "homepage": "https://react-tourlight.dev",
  "engines": {
    "node": ">=18.0.0"
  },
  "type": "module",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.mts",
        "default": "./dist/index.mjs"
      }
    },
    "./styles.css": "./dist/styles/spotlight.css"
  },
  "main": "./dist/index.mjs",
  "types": "./dist/index.d.mts",
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "sideEffects": [
    "*.css"
  ],
  "keywords": [
    "react",
    "spotlight",
    "tourlight",
    "tour",
    "onboarding",
    "product-tour",
    "walkthrough",
    "tooltip",
    "joyride",
    "highlight",
    "guide",
    "feature-highlight",
    "clip-path",
    "accessible"
  ],
  "peerDependencies": {
    "@floating-ui/react-dom": ">=2.0.0",
    "react": ">=18.0.0",
    "react-dom": ">=18.0.0"
  },
  "peerDependenciesMeta": {
    "@floating-ui/react-dom": {
      "optional": true
    }
  },
  "devDependencies": {
    "@biomejs/biome": "^2.3.0",
    "@changesets/changelog-github": "^0.5.0",
    "@changesets/cli": "^2.27.0",
    "@floating-ui/react-dom": "^2.1.0",
    "@testing-library/jest-dom": "^6.0.0",
    "@testing-library/react": "^16.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "jsdom": "^25.0.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "@arethetypeswrong/cli": "^0.17.0",
    "publint": "^0.3.0",
    "tsdown": "0.21.0-beta.2",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0"
  },
  "scripts": {
    "build": "tsdown",
    "dev": "tsdown --watch",
    "test": "vitest",
    "test:run": "vitest run",
    "test:coverage": "vitest run --coverage",
    "check": "biome check .",
    "check:fix": "biome check --fix .",
    "lint:pkg": "publint && attw --pack .",
    "validate": "pnpm run build && pnpm run lint:pkg && pnpm run check && pnpm run test:run",
    "prepublishOnly": "pnpm run build",
    "changeset": "changeset",
    "version": "changeset version",
    "release": "pnpm run build && changeset publish"
  }
}
